# Test Environment Variables
# Copy from .env and modify for testing

NODE_ENV=test

# Database
DATABASE_URL=postgres://user:password@localhost:5432/fuelripple_test

# Redis
REDIS_URL=redis://localhost:6379/1

# API Config
PORT=3001
API_ENV=test

# External Services (use test/mock endpoints)
EIA_API_KEY=test_key
FRED_API_KEY=test_key

# Feature Flags
ENABLE_CACHE=false
ENABLE_CRON_JOBS=false
