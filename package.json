{
  "name": "fuelripple",
  "version": "1.0.4",
  "private": true,
  "description": "US Gas Price Tracker & Consumer Disruption Index",
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test --parallel",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "clean": "turbo run clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:migrate": "npm run --workspace=@fuelripple/db migrate",
    "db:seed": "npm run --workspace=@fuelripple/db seed",
    "db:backfill": "npm run backfill --workspace=@fuelripple/api",
    "backfill": "npm run backfill --workspace=@fuelripple/api",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major",
    "version:patch:api": "node scripts/bump-version.js patch api",
    "version:patch:web": "node scripts/bump-version.js patch web",
    "version:minor:api": "node scripts/bump-version.js minor api",
    "version:minor:web": "node scripts/bump-version.js minor web",
    "version:beta:patch": "node scripts/bump-version.js pre-patch",
    "version:beta:minor": "node scripts/bump-version.js pre-minor",
    "version:beta:major": "node scripts/bump-version.js pre-major",
    "version:beta:patch:api": "node scripts/bump-version.js pre-patch api",
    "version:beta:patch:web": "node scripts/bump-version.js pre-patch web",
    "version:release": "node scripts/bump-version.js release",
    "version:release:api": "node scripts/bump-version.js release api",
    "version:release:web": "node scripts/bump-version.js release web"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.0",
    "@types/jest": "^29.5.0",
    "@types/supertest": "^2.0.12",
    "@vitest/ui": "^1.0.0",
    "jest": "^29.7.0",
    "jsdom": "^22.1.0",
    "prettier": "^3.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "supertest": "^6.3.0",
    "ts-jest": "^29.1.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
